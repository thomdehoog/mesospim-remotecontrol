+
+def _stat_files(core, a):
+    files = [str(f) for f in (a.get("files") or [])]
+    return {"missing": [f for f in files if not os.path.isfile(f)],
+            "sizes": {f: os.path.getsize(f) for f in files if os.path.isfile(f)}}
